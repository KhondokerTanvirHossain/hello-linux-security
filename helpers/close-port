#!/bin/bash
# close-port — Close a port in firewalld
# Usage: close-port <port> [tcp|udp]
# Installed to /usr/local/bin/ by harden.sh
# Note: {{SSH_PORT}} is replaced by harden.sh during install with the actual SSH port.

set -euo pipefail

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# SSH port — replaced by harden.sh during install (sed replaces {{SSH_PORT}})
# ---------------------------------------------------------------------------
SSH_PORT="{{SSH_PORT}}"

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    echo -e "${YELLOW}Usage:${NC} close-port <port> [tcp|udp]"
    echo ""
    echo "  port    Port number (1-65535)"
    echo "  proto   Protocol: tcp (default) or udp"
    echo ""
    echo "Examples:"
    echo "  close-port 8080"
    echo "  close-port 53 udp"
    exit 1
}

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------
if [[ $# -lt 1 ]]; then
    usage
fi

PORT="$1"
PROTO="${2:-tcp}"

# Validate port is a number
if ! [[ "$PORT" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}[ERROR]${NC} Port must be a number. Got: $PORT"
    exit 1
fi

# Validate port range
if (( PORT < 1 || PORT > 65535 )); then
    echo -e "${RED}[ERROR]${NC} Port must be between 1 and 65535. Got: $PORT"
    exit 1
fi

# Validate protocol
if [[ "$PROTO" != "tcp" && "$PROTO" != "udp" ]]; then
    echo -e "${RED}[ERROR]${NC} Protocol must be tcp or udp. Got: $PROTO"
    exit 1
fi

# ---------------------------------------------------------------------------
# Safety check: refuse to close the SSH port
# ---------------------------------------------------------------------------
if [[ "$PORT" == "$SSH_PORT" && "$PROTO" == "tcp" ]]; then
    echo -e "${RED}[ERROR]${NC} Refusing to close port ${PORT}/tcp — this is your SSH port!"
    echo -e "${RED}[ERROR]${NC} Closing it would lock you out of the server."
    exit 1
fi

# ---------------------------------------------------------------------------
# Close the port
# ---------------------------------------------------------------------------
echo -e "${YELLOW}[INFO]${NC} Closing port ${PORT}/${PROTO}..."

sudo firewall-cmd --permanent --remove-port="${PORT}/${PROTO}"
sudo firewall-cmd --reload

echo -e "${GREEN}[OK]${NC} Port ${PORT}/${PROTO} is now closed."
echo ""

# ---------------------------------------------------------------------------
# Show current open ports
# ---------------------------------------------------------------------------
echo -e "${YELLOW}Current open ports:${NC}"
sudo firewall-cmd --list-ports
