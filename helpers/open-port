#!/bin/bash
# open-port — Open a port in firewalld
# Usage: open-port <port> [tcp|udp]
# Installed to /usr/local/bin/ by harden.sh

set -euo pipefail

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    echo -e "${YELLOW}Usage:${NC} open-port <port> [tcp|udp]"
    echo ""
    echo "  port    Port number (1-65535)"
    echo "  proto   Protocol: tcp (default) or udp"
    echo ""
    echo "Examples:"
    echo "  open-port 8080"
    echo "  open-port 53 udp"
    exit 1
}

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------
if [[ $# -lt 1 ]]; then
    usage
fi

PORT="$1"
PROTO="${2:-tcp}"

# Validate port is a number
if ! [[ "$PORT" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}[ERROR]${NC} Port must be a number. Got: $PORT"
    exit 1
fi

# Validate port range
if (( PORT < 1 || PORT > 65535 )); then
    echo -e "${RED}[ERROR]${NC} Port must be between 1 and 65535. Got: $PORT"
    exit 1
fi

# Validate protocol
if [[ "$PROTO" != "tcp" && "$PROTO" != "udp" ]]; then
    echo -e "${RED}[ERROR]${NC} Protocol must be tcp or udp. Got: $PROTO"
    exit 1
fi

# ---------------------------------------------------------------------------
# Open the port
# ---------------------------------------------------------------------------
echo -e "${YELLOW}[INFO]${NC} Opening port ${PORT}/${PROTO}..."

sudo firewall-cmd --permanent --add-port="${PORT}/${PROTO}"
sudo firewall-cmd --reload

echo -e "${GREEN}[OK]${NC} Port ${PORT}/${PROTO} is now open."
echo ""

# ---------------------------------------------------------------------------
# Show current open ports
# ---------------------------------------------------------------------------
echo -e "${YELLOW}Current open ports:${NC}"
sudo firewall-cmd --list-ports
